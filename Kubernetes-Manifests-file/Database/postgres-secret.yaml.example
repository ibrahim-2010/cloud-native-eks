apiVersion: v1
kind: Secret
metadata:
  name: postgres-secret
  namespace: three-tier
type: Opaque
data:
  # Base64-encode your values before setting them here:
  #   echo -n 'YOUR_VALUE' | base64
  #
  # Then copy this file to postgres-secret.yaml (gitignored) and fill in the values.
  # Apply with: kubectl apply -f postgres-secret.yaml
  POSTGRES_USER: <base64-encoded-username>
  POSTGRES_PASSWORD: <base64-encoded-password>
  POSTGRES_DB: <base64-encoded-dbname>
